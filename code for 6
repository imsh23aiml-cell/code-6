pipeline {
agent any


tools {
    maven 'mvn'
    jdk 'jdk'
}

stages {
    stage('Checkout') {
        steps {
            git branch: 'main', url: 'https://github.com/imsh23aiml-cell/exam-pro-6.git'
        }
    }

    stage('Build') {
        steps {
            bat 'mvn clean package'
        }
    }

    stage('Test') {
        steps {
            bat 'mvn test'
        }
    }
}

post {
    always {
        junit allowEmptyResults: true, testResults: '**/target/surefire-reports/*.xml'
    }
}


}
